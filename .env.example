DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
JWT_SECRET=replace_with_a_new_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

BACKEND_CORS_ORIGINS=https://your-site.pages.dev
BACKEND_ALLOW_LOCAL_ORIGINS=true
FRONTEND_URL=https://your-site.pages.dev
PASSWORD_RESET_URL=https://your-site.pages.dev/#account
SUPPORT_EMAIL=progeomapper@gmail.com
ANALYTICS_ENABLED=true
RATE_LIMIT_ENABLED=true

APP_SMTP_HOST=smtp.gmail.com
APP_SMTP_PORT=465
APP_SMTP_EMAIL=no-reply@example.com
APP_SMTP_PASSWORD=your_smtp_app_password
APP_SMTP_FROM_NAME=GeoMapper Pro

# Desktop app update metadata served by /app/version.
APP_RELEASE_CHANNEL=stable
APP_LATEST_VERSION=1.1.2
APP_MIN_SUPPORTED_VERSION=1.1.2
APP_DOWNLOAD_URL=https://github.com/MOUHANEDXIX/geomapper-pro-downloads/releases/latest/download/GeoMapperProSetup.exe
APP_RELEASE_NOTES=GeoMapper Pro 1.1.2: adds OTC reference-control calibration, improves polynomial inversion and Carthage UTM/STT conversions, and packages the calibration dataset in the Windows installer.
APP_RELEASE_SHA256=9A5A6BC35A5FBA3E4352C593833A57BA42CF78FF065F09B1276A3A7BC3D94339
APP_INSTALLER_FILENAME=GeoMapperProSetup.exe
APP_INSTALLER_SIZE_BYTES=147856263
APP_UPDATE_REQUIRED=true

# Optional: use Brevo's HTTPS transactional email API instead of SMTP.
# This is useful on free hosts that block outbound SMTP ports.
BREVO_API_KEY=
APP_EMAIL_FROM_EMAIL=no-reply@example.com

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=replace_with_a_strong_password
